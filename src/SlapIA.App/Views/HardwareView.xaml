<UserControl x:Class="SlapIA.App.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:SlapIA.App.Models"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Button Grid.Row="0" Content="Actualiser" Command="{Binding RefreshCommand}"
                   Appearance="Secondary"
                   HorizontalAlignment="Right" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding Snapshot}">

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Processeur" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding Processor.Name, FallbackValue=-, TargetNullValue=-}" Style="{StaticResource ValueText}"/>
                        <TextBlock Style="{StaticResource LabelText}" Margin="0,4,0,0">
                            <Run Text="{Binding Processor.Cores, FallbackValue=0, Mode=OneWay}"/><Run Text=" coeurs / "/>
                            <Run Text="{Binding Processor.LogicalProcessors, FallbackValue=0, Mode=OneWay}"/><Run Text=" threads @ "/>
                            <Run Text="{Binding Processor.MaxClockSpeedGHz, FallbackValue=0, Mode=OneWay, StringFormat={}{0:0.00} GHz}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Memoire vive" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Style="{StaticResource ValueText}">
                            <Run Text="{Binding Memory.TotalGB, FallbackValue=0, Mode=OneWay, StringFormat={}{0:0.#} Go}"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource LabelText}" Margin="0,4,0,0">
                            <Run Text="{Binding Memory.ModuleCount, FallbackValue=0, Mode=OneWay}"/><Run Text=" barrette(s) - "/>
                            <Run Text="{Binding Memory.MemoryType, FallbackValue=-, Mode=OneWay}"/><Run Text=" - "/>
                            <Run Text="{Binding Memory.SpeedMHz, FallbackValue=-, Mode=OneWay}"/><Run Text=" MHz"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Cartes graphiques" Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding GraphicsCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GraphicsCardInfo}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource ValueText}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelText}">
                                            <Run Text="{Binding VramGB, Mode=OneWay, StringFormat={}{0:0.#} Go VRAM}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Disques physiques" Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DiskInfo}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Model}" Style="{StaticResource ValueText}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelText}">
                                            <Run Text="{Binding SizeGB, Mode=OneWay, StringFormat={}{0:0.#} Go}"/><Run Text=" - "/>
                                            <Run Text="{Binding MediaType, Mode=OneWay}"/><Run Text=" - "/>
                                            <Run Text="{Binding InterfaceType, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Volumes" Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding Volumes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:VolumeInfo}">
                                    <StackPanel Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource ValueText}" FontSize="14">
                                                <Run Text="{Binding Letter, Mode=OneWay}"/>
                                                <Run Text="{Binding Label, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Style="{StaticResource LabelText}">
                                                <Run Text="{Binding FreeGB, Mode=OneWay, StringFormat={}{0:0.#} Go libres sur }"/>
                                                <Run Text="{Binding TotalGB, Mode=OneWay, StringFormat={}{0:0.#} Go}"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Reseau" Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding NetworkAdapters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:NetworkAdapterInfo}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource ValueText}" FontSize="14"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource LabelText}">
                                            <Run Text="{Binding IPv4Address, Mode=OneWay, FallbackValue=-, TargetNullValue=-}"/><Run Text=" - "/>
                                            <Run Text="{Binding MacAddress, Mode=OneWay, FallbackValue=-, TargetNullValue=-}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Carte mere / BIOS" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Style="{StaticResource ValueText}">
                            <Run Text="{Binding MotherboardManufacturer, FallbackValue=-, TargetNullValue=-}"/>
                            <Run Text="{Binding MotherboardModel, FallbackValue=-, TargetNullValue=-}"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource LabelText}" Margin="0,4,0,0">
                            <Run Text="BIOS "/><Run Text="{Binding BiosVersion, FallbackValue=-, TargetNullValue=-}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
