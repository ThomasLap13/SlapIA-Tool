<Window x:Class="SlapIA.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:SlapIA.App.ViewModels"
        xmlns:views="clr-namespace:SlapIA.App.Views"
        xmlns:loc="clr-namespace:SlapIA.App.Services"
        mc:Ignorable="d"
        Title="SlapIA Tool" Height="740" Width="1180" MinHeight="580" MinWidth="960"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HardwareViewModel}">
            <views:HardwareView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonitoringViewModel}">
            <views:MonitoringView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SoftwareViewModel}">
            <views:SoftwareView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,4,0,16">
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,24">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Assets/logo.png" Width="30" Height="30" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SlapIA" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tool" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,-4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,12,16,0">
                    <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,12"/>
                    <Button Content="{loc:Tr Sidebar_CheckUpdates}" Command="{Binding CheckForUpdatesCommand}"
                            Style="{StaticResource PillButtonStyle}" HorizontalAlignment="Stretch"
                            Height="36" Padding="12,8" FontSize="12.5"
                            IsEnabled="{Binding IsCheckingForUpdate, Converter={StaticResource InverseBooleanConverter}}"/>
                    <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource LabelText}"
                               TextWrapping="Wrap" Margin="2,8,2,0"
                               Visibility="{Binding UpdateStatus, Converter={StaticResource StringToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding AppVersion}" Style="{StaticResource LabelText}" Margin="2,8,0,0" HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="2,10,2,0">
                        <TextBlock Text="{loc:Tr Language_French}" Cursor="Hand" FontSize="11" Margin="0,0,10,0"
                                   MouseLeftButtonUp="LanguageFr_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentLanguage}" Value="fr">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{loc:Tr Language_English}" Cursor="Hand" FontSize="11"
                                   MouseLeftButtonUp="LanguageEn_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=CurrentLanguage}" Value="en">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="{loc:Tr Sidebar_Section_General}" Style="{StaticResource LabelText}" Margin="24,0,0,8" FontSize="10.5" FontWeight="SemiBold"/>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Tag="overview"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=overview, Mode=OneWay}"
                                 Command="{Binding NavigateOverviewCommand}" Checked="NavRadioButton_Checked" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource NavHomeIconGeometry}" Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" StrokeThickness="1.3" StrokeLineJoin="Round" Stretch="Uniform" Width="15" Height="15" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Tr Nav_Overview}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Tag="hardware"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=hardware, Mode=OneWay}"
                                 Command="{Binding NavigateHardwareCommand}" Checked="NavRadioButton_Checked" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource NavHardwareIconGeometry}" Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" StrokeThickness="1.3" StrokeLineJoin="Round" Stretch="Uniform" Width="15" Height="15" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Tr Nav_Hardware}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Tag="monitoring"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=monitoring, Mode=OneWay}"
                                 Command="{Binding NavigateMonitoringCommand}" Checked="NavRadioButton_Checked" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource NavMonitoringIconGeometry}" Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" StrokeThickness="1.3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Stretch="Uniform" Width="15" Height="15" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Tr Nav_Monitoring}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Tag="software"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=software, Mode=OneWay}"
                                 Command="{Binding NavigateSoftwareCommand}" Checked="NavRadioButton_Checked" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource NavSoftwareIconGeometry}" Stroke="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" StrokeThickness="1.3" StrokeLineJoin="Round" Stretch="Uniform" Width="15" Height="15" Margin="0,0,10,0"/>
                            <TextBlock Text="{loc:Tr Nav_Software}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding CurrentPageTitle}" Style="{StaticResource PageTitleText}" Margin="0,0,0,20"/>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
