<Window x:Class="SlapIA.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:SlapIA.App.ViewModels"
        xmlns:views="clr-namespace:SlapIA.App.Views"
        mc:Ignorable="d"
        Title="SlapIA Tool" Height="740" Width="1180" MinHeight="580" MinWidth="960"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:OverviewViewModel}">
            <views:OverviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HardwareViewModel}">
            <views:HardwareView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonitoringViewModel}">
            <views:MonitoringView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SoftwareViewModel}">
            <views:SoftwareView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,4,0,16">
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="7" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="S" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextOnAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SlapIA" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tool" FontSize="17" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,-4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="GENERAL" Style="{StaticResource LabelText}" Margin="24,0,0,8" FontSize="10.5" FontWeight="SemiBold"/>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Content="Vue d'ensemble"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=overview, Mode=OneWay}"
                                 Command="{Binding NavigateOverviewCommand}" Margin="0,0,0,2"/>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Content="Materiel"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=hardware, Mode=OneWay}"
                                 Command="{Binding NavigateHardwareCommand}" Margin="0,0,0,2"/>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Content="Monitoring"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=monitoring, Mode=OneWay}"
                                 Command="{Binding NavigateMonitoringCommand}" Margin="0,0,0,2"/>

                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Content="Logiciels installes"
                                 IsChecked="{Binding SelectedNavKey, Converter={StaticResource NavSelectionConverter}, ConverterParameter=software, Mode=OneWay}"
                                 Command="{Binding NavigateSoftwareCommand}" Margin="0,0,0,2"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding CurrentPageTitle}" Style="{StaticResource PageTitleText}" Margin="0,0,0,20"/>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
